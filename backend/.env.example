#############################################
# .env.example
# 복사하여 backend/.env 로 사용하세요:
#   cp .env.example .env
# 필요한 값만 수정 (비밀 값은 절대 커밋하지 마세요)
#############################################

# 기본 메타
PROJECT_NAME=SelfStar Backend
VERSION=0.1.0
ENV=dev
LOG_LEVEL=info
ALLOWED_ORIGINS=*

# MySQL (docker-compose 사용 시)
# 컨테이너 링크 이름이 mysql 이므로 아래 host 유지
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=appuser
DB_PASSWORD=apppass
DB_NAME=appdb
DB_ECHO=false

# 로컬 호스트 MySQL 직접 접속 시 (선택)
# DB_HOST=127.0.0.1

# 참고: async DB URL 은 코드에서 조합됨 (config.async_database_url)
# 필요 시 직접 override 가능
# ASYNC_DATABASE_URL=mysql+asyncmy://appuser:apppass@mysql:3306/appdb

# --- 추가 확장 (예정) ---
# JWT_SECRET=changeme
# JWT_ALG=HS256
# PAGE_SIZE_DEFAULT=20
